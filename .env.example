HTT_APP_NAME=Hidden Transmission Tunnel
HTT_ENV=development
HTT_ADMIN_API_KEY=replace-with-a-long-random-secret
HTT_ADMIN_ALLOWED_IPS=["127.0.0.1","::1"]
HTT_TRUST_PROXY_HEADERS=false
HTT_APP_SECRET=replace-with-a-separate-long-random-secret
HTT_ALLOWED_ORIGINS=["http://localhost:3000"]
HTT_REDIS_URL=redis://localhost:6379/0
HTT_MONGODB_URL=mongodb://localhost:27017
HTT_MONGODB_DB=hidden_transmission_tunnel
HTT_ENABLE_MESSAGE_PERSISTENCE=false
HTT_MESSAGE_TTL_SECONDS=86400
HTT_JOIN_TICKET_TTL_SECONDS=90
HTT_RATE_LIMIT_MESSAGES=12
HTT_RATE_LIMIT_WINDOW_SECONDS=10
HTT_BRUTE_FORCE_LIMIT=8
HTT_BRUTE_FORCE_WINDOW_SECONDS=300
HTT_BRUTE_FORCE_REPLENISH_SECONDS=5
HTT_BRUTE_FORCE_LOCK_SECONDS=1800
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

